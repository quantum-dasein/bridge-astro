---
interface Props {
	active?: string;
	lang?: string;
}
const { active = 'news', lang = 'ru' } = Astro.props;

// Если мы на странице конкретной новости, URL генерируется в [slug].astro, 
// иначе даем дефолтные ссылки на разделы
const newsUrl = lang === 'en' ? '/news/en/' : lang === 'uz' ? '/news/uz/' : '/news/';

// Словарь переводов для шапки
const navDict = {
	ru: {
		company: 'О компании',
		services: 'Услуги',
		projects: 'Проекты',
		news: 'Новости',
		training: 'Тренинги FIDIC',
		expertise: 'Экспертиза',
		contactBtn: 'Оставить заявку',
		team: 'Лица компании',
		faq: 'База знаний (FAQ)',
		media: 'СМИ и Публикации'
	},
	en: {
		company: 'Company',
		services: 'Services',
		projects: 'Projects',
		news: 'Newsroom',
		training: 'FIDIC Training',
		expertise: 'Expertise',
		contactBtn: 'Submit Request',
		team: 'Our Team',
		faq: 'Knowledge Base (FAQ)',
		media: 'Media & Publications'
	},
	uz: {
		company: 'Kompaniya haqida',
		services: 'Xizmatlar',
		projects: 'Loyihalar',
		news: 'Yangiliklar',
		training: 'FIDIC Treninglari',
		expertise: 'Ekspertiza',
		contactBtn: 'Ariza qoldirish',
		team: 'Kompaniya yuzlari',
		faq: 'Bilimlar bazasi (FAQ)',
		media: 'OAV va Nashrlar'
	}
};

const t = navDict[lang as keyof typeof navDict] || navDict.ru;
---

<header class="fixed w-full top-0 z-[100] bg-bridge-dark/60 backdrop-blur-xl border-b border-white/10 transition-all duration-300">
	<div class="max-w-[1400px] mx-auto px-4 md:px-6 h-20 flex items-center justify-between relative z-[101]">
		<a href="/index.html" class="relative z-[101] block shrink-0">
			<img src="/bridge 2.svg" alt="Bridge Consult" class="site-logo h-9 md:h-11 object-contain relative z-[101]" style="filter: brightness(0) invert(1);" />
		</a>

		<nav class="hidden lg:flex items-center space-x-6 lg:space-x-8">
			<a href="/index.html#about" class="nav-link text-sm font-medium text-gray-300 hover:text-bridge-taupe transition-colors whitespace-nowrap">{t.company}</a>
			<a href="/index.html#services" class="nav-link text-sm font-medium text-gray-300 hover:text-bridge-taupe transition-colors whitespace-nowrap">{t.services}</a>
			<a href="/projects.html" class="nav-link text-sm font-medium text-gray-300 hover:text-bridge-taupe transition-colors whitespace-nowrap">{t.projects}</a>
			<a href={newsUrl} class:list={["nav-link text-sm font-medium transition-colors whitespace-nowrap", active === 'news' ? 'text-bridge-taupe is-active' : 'text-gray-300 hover:text-bridge-taupe']}>
				{t.news}
			</a>
			<a href="/index.html#trainings" class="nav-link text-sm font-bold text-bridge-taupe hover:text-white transition-colors whitespace-nowrap">{t.training}</a>

			<div class="relative group">
				<button type="button" class="nav-link text-sm font-medium text-gray-300 hover:text-bridge-taupe transition-colors flex items-center gap-1.5 cursor-pointer whitespace-nowrap py-4">
					{t.expertise}
					<svg class="w-3.5 h-3.5 transition-transform duration-300 group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
				</button>
				<div class="absolute top-full right-0 mt-0 w-64 bg-bridge-dark/90 backdrop-blur-xl border border-white/10 rounded-2xl shadow-[0_20px_40px_-10px_rgba(0,0,0,0.5)] py-3 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 transform translate-y-2 group-hover:translate-y-0 z-50">
					<a href="/index.html#team" class="flex items-center gap-3 px-5 py-3 text-sm text-gray-300 hover:text-bridge-taupe hover:bg-white/5 transition-colors mx-2 rounded-xl">
						<svg class="w-4 h-4 text-bridge-taupe opacity-70 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
						{t.team}
					</a>
					<a href="/index.html#faq" class="flex items-center gap-3 px-5 py-3 text-sm text-gray-300 hover:text-bridge-taupe hover:bg-white/5 transition-colors mx-2 rounded-xl">
						<svg class="w-4 h-4 text-bridge-taupe opacity-70 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477-4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path></svg>
						{t.faq}
					</a>
					<a href="/index.html#media" class="flex items-center gap-3 px-5 py-3 text-sm text-gray-300 hover:text-bridge-taupe hover:bg-white/5 transition-colors mx-2 rounded-xl">
						<svg class="w-4 h-4 text-bridge-taupe opacity-70 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"></path></svg>
						{t.media}
					</a>
				</div>
			</div>
		</nav>

		<div class="hidden lg:flex items-center space-x-4">
			<div class="flex items-center space-x-1.5 pr-4 border-r border-white/10 font-bold text-xs uppercase tracking-widest">
				<a href="/news/" class:list={[lang === 'ru' ? 'text-bridge-taupe border-b-2 border-bridge-taupe pb-0.5' : 'text-gray-400 hover:text-bridge-taupe transition-colors pb-0.5']}>RU</a>
				<span class="text-white/20">|</span>
				<a href="/news/en/" class:list={[lang === 'en' ? 'text-bridge-taupe border-b-2 border-bridge-taupe pb-0.5' : 'text-gray-400 hover:text-bridge-taupe transition-colors pb-0.5']}>EN</a>
				<span class="text-white/20">|</span>
				<a href="/news/uz/" class:list={[lang === 'uz' ? 'text-bridge-taupe border-b-2 border-bridge-taupe pb-0.5' : 'text-gray-400 hover:text-bridge-taupe transition-colors pb-0.5']}>UZ</a>
			</div>
			<div class="flex items-center space-x-3">
				<a href="tel:+998330001530" class="text-xs font-bold text-white hover:text-bridge-taupe transition-colors tracking-wide whitespace-nowrap">+998 33 000 15 30</a>
				<a href="/index.html#contact-form" class="bg-bridge-taupe text-white px-5 py-2.5 rounded-full text-[10px] font-bold uppercase tracking-widest hover:bg-white hover:text-bridge-dark transition-colors shadow-md whitespace-nowrap">{t.contactBtn}</a>
			</div>
		</div>
	</div>
</header>
