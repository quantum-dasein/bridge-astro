---
interface Props {
	active?: string;
	lang?: string;
}
const { active = 'news', lang = 'ru' } = Astro.props;
const newsUrl = lang === 'en' ? '/news/en/' : lang === 'uz' ? '/news/uz/' : '/news/';
const langLinks = {
	ru: { href: '/news/', label: 'RU', active: lang === 'ru' },
	en: { href: '/news/en/', label: 'EN', active: lang === 'en' },
	uz: { href: '/news/uz/', label: 'UZ', active: lang === 'uz' },
};
---

<header class="fixed w-full top-0 z-[100] bg-bridge-dark/60 backdrop-blur-xl border-b border-white/10 transition-all duration-300">
	<div class="max-w-[1400px] mx-auto px-4 md:px-6 h-20 flex items-center justify-between relative z-[101]">
		<a href="/index.html" class="relative z-[101] block shrink-0">
			<img src="/bridge 2.svg" alt="Bridge Consult" class="site-logo h-9 md:h-11 object-contain relative z-[101]" style="filter: brightness(0) invert(1);" />
		</a>

		<nav class="hidden lg:flex items-center space-x-6 lg:space-x-8">
			<a href="/index.html#about" class="nav-link text-sm font-medium text-gray-300 hover:text-bridge-taupe transition-colors whitespace-nowrap">О компании</a>
			<a href="/index.html#services" class="nav-link text-sm font-medium text-gray-300 hover:text-bridge-taupe transition-colors whitespace-nowrap">Услуги</a>
			<a href="/projects.html" class="nav-link text-sm font-medium text-gray-300 hover:text-bridge-taupe transition-colors whitespace-nowrap">Проекты</a>
			<a href={newsUrl} class:list={["nav-link text-sm font-medium transition-colors whitespace-nowrap", active === 'news' ? 'text-bridge-taupe is-active' : 'text-gray-300 hover:text-bridge-taupe']}>
			{lang === 'en' ? 'News' : lang === 'uz' ? 'Yangiliklar' : 'Новости'}
		</a>
			<a href="/index.html#trainings" class="nav-link text-sm font-bold text-bridge-taupe hover:text-white transition-colors whitespace-nowrap">Тренинги FIDIC</a>

			<div class="relative group">
				<button type="button" class="nav-link text-sm font-medium text-gray-300 hover:text-bridge-taupe transition-colors flex items-center gap-1.5 cursor-pointer whitespace-nowrap py-4">
					Экспертиза
					<svg class="w-3.5 h-3.5 transition-transform duration-300 group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
				</button>
				<div class="absolute top-full right-0 mt-0 w-64 bg-bridge-dark/90 backdrop-blur-xl border border-white/10 rounded-2xl shadow-[0_20px_40px_-10px_rgba(0,0,0,0.5)] py-3 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 transform translate-y-2 group-hover:translate-y-0 z-50">
					<a href="/index.html#team" class="flex items-center gap-3 px-5 py-3 text-sm text-gray-300 hover:text-bridge-taupe hover:bg-white/5 transition-colors mx-2 rounded-xl">
						<svg class="w-4 h-4 text-bridge-taupe opacity-70 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
						Лица компании
					</a>
					<a href="/index.html#faq" class="flex items-center gap-3 px-5 py-3 text-sm text-gray-300 hover:text-bridge-taupe hover:bg-white/5 transition-colors mx-2 rounded-xl">
						<svg class="w-4 h-4 text-bridge-taupe opacity-70 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path></svg>
						База знаний (FAQ)
					</a>
					<a href="/index.html#media" class="flex items-center gap-3 px-5 py-3 text-sm text-gray-300 hover:text-bridge-taupe hover:bg-white/5 transition-colors mx-2 rounded-xl">
						<svg class="w-4 h-4 text-bridge-taupe opacity-70 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"></path></svg>
						СМИ и Публикации
					</a>
				</div>
			</div>
		</nav>

		<div class="hidden lg:flex items-center space-x-4">
			<div class="flex items-center space-x-2 pr-4 border-r border-white/10">
				<a href="https://www.linkedin.com/in/larissalk" target="_blank" class="w-9 h-9 rounded-full bg-white/5 flex items-center justify-center text-bridge-taupe hover:bg-bridge-taupe hover:text-white transition-all duration-300" title="LinkedIn">
					<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
				</a>
				<a href="https://t.me/fidicuzb" target="_blank" class="w-9 h-9 rounded-full bg-white/5 flex items-center justify-center text-bridge-taupe hover:bg-bridge-taupe hover:text-white transition-all duration-300" title="Telegram">
					<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm4.64 6.8c-.15 1.58-.8 5.42-1.13 7.19-.14.75-.42 1-.68 1.03-.58.05-1.02-.38-1.58-.75-.88-.58-1.38-.94-2.23-1.5-.99-.65-.35-1.01.22-1.59.15-.15 2.71-2.48 2.76-2.69.01-.03.01-.14-.07-.19-.08-.05-.19-.02-.27 0-.11.03-1.84 1.18-5.2 3.45-.49.33-.94.5-1.35.49-.45-.01-1.3-.25-1.94-.46-.78-.26-1.4-.4-1.34-.84.03-.23.36-.47.98-.72 3.85-1.68 6.42-2.78 7.71-3.32 3.67-1.53 4.43-1.8 4.93-1.81.11 0 .36.03.49.13.11.09.14.22.15.34.01.07.01.18 0 .22z"/></svg>
				</a>
			</div>

			<div class="flex items-center space-x-1.5 pr-4 border-r border-white/10 font-bold text-xs uppercase tracking-widest">
				<a href="/news/" class:list={[lang === 'ru' ? 'text-bridge-taupe border-b-2 border-bridge-taupe pb-0.5' : 'text-gray-400 hover:text-bridge-taupe transition-colors pb-0.5']}>RU</a>
				<span class="text-white/20">|</span>
				<a href="/news/en/" class:list={[lang === 'en' ? 'text-bridge-taupe border-b-2 border-bridge-taupe pb-0.5' : 'text-gray-400 hover:text-bridge-taupe transition-colors pb-0.5']}>EN</a>
				<span class="text-white/20">|</span>
				<a href="/news/uz/" class:list={[lang === 'uz' ? 'text-bridge-taupe border-b-2 border-bridge-taupe pb-0.5' : 'text-gray-400 hover:text-bridge-taupe transition-colors pb-0.5']}>UZ</a>
			</div>

			<button id="theme-toggle" type="button" title="Сменить тему" class="shrink-0 text-gray-400 hover:text-bridge-taupe focus:outline-none">
				<svg id="theme-toggle-dark-icon" class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"></path></svg>
				<svg id="theme-toggle-light-icon" class="hidden w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z"></path></svg>
			</button>

			<div class="flex items-center space-x-3">
				<a href="tel:+998330001530" class="text-xs font-bold text-white hover:text-bridge-taupe transition-colors tracking-wide whitespace-nowrap">+998 33 000 15 30</a>
				<a href="/index.html#contact-form" class="bg-bridge-taupe text-white px-5 py-2.5 rounded-full text-[10px] font-bold uppercase tracking-widest hover:bg-white hover:text-bridge-dark transition-colors shadow-md whitespace-nowrap">Оставить заявку</a>
			</div>
		</div>

		<button id="mobile-menu-btn" class="lg:hidden flex flex-col justify-between w-7 h-5 text-white focus:outline-none relative z-[101] cursor-pointer">
			<span class="w-full h-[2px] bg-current transition-all duration-300 origin-left burger-line-1"></span>
			<span class="w-full h-[2px] bg-current transition-all duration-300 burger-line-2"></span>
			<span class="w-full h-[2px] bg-current transition-all duration-300 origin-left burger-line-3"></span>
		</button>
	</div>

	<div id="mobile-menu" class="fixed inset-0 w-full h-[100dvh] bg-bridge-dark z-[100] flex flex-col p-8 transition-transform duration-500 translate-x-full lg:hidden pt-28 overflow-y-auto">
		<div class="flex items-center justify-center space-x-6 mb-10 pb-6 border-b border-white/10 font-bold text-sm uppercase tracking-widest font-sans">
			<a href="/news/" class:list={[lang === 'ru' ? 'text-bridge-taupe border-b-2 border-bridge-taupe pb-1' : 'text-gray-400 hover:text-bridge-taupe transition-colors pb-1']}>RU</a>
			<a href="/news/en/" class:list={[lang === 'en' ? 'text-bridge-taupe border-b-2 border-bridge-taupe pb-1' : 'text-gray-400 hover:text-bridge-taupe transition-colors pb-1']}>EN</a>
			<a href="/news/uz/" class:list={[lang === 'uz' ? 'text-bridge-taupe border-b-2 border-bridge-taupe pb-1' : 'text-gray-400 hover:text-bridge-taupe transition-colors pb-1']}>UZ</a>
			<button id="mobile-theme-toggle" type="button" class="text-gray-400 hover:text-bridge-taupe transition-colors focus:outline-none ml-2" title="Сменить тему">
				<svg id="mobile-theme-toggle-dark-icon" class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"></path></svg>
				<svg id="mobile-theme-toggle-light-icon" class="hidden w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z"></path></svg>
			</button>
		</div>
		<div class="flex flex-col space-y-5 font-sans pb-8">
			<a href="/index.html#about" class="mobile-nav-link text-2xl font-bold text-white border-b border-white/10 pb-3">О компании</a>
			<a href="/index.html#services" class="mobile-nav-link text-2xl font-bold text-white border-b border-white/10 pb-3">Услуги</a>
			<a href="/projects.html" class="mobile-nav-link text-2xl font-bold text-white border-b border-white/10 pb-3">Проекты</a>
			<a href={newsUrl} class="mobile-nav-link text-2xl font-bold text-bridge-taupe border-b border-white/10 pb-3">
			{lang === 'en' ? 'News' : lang === 'uz' ? 'Yangiliklar' : 'Новости'}
		</a>
			<a href="/index.html#trainings" class="mobile-nav-link text-2xl font-bold text-bridge-taupe border-b border-white/10 pb-3">Тренинги FIDIC</a>
			<a href="/index.html#contact-form" class="mobile-nav-link text-2xl font-bold text-white border-b border-white/10 pb-3 pt-4">Оставить заявку</a>
		</div>
	</div>
</header>

<style>
	.nav-link.is-active {
		position: relative;
	}
	.nav-link.is-active::after {
		content: '';
		position: absolute;
		left: 0;
		bottom: -4px;
		width: 100%;
		height: 2px;
		background-color: #8A7B66;
	}
</style>
