---
interface Props {
  lang?: string;
  langUrls?: { ru: string; en: string; uz: string };
}
const { lang = 'ru', langUrls } = Astro.props;

const home     = lang === 'uz' ? '/UZ/index.html' : lang === 'en' ? '/EN/index.html' : '/index.html';
const projects = lang === 'uz' ? '/UZ/projects.html' : lang === 'en' ? '/EN/projects.html' : '/projects.html';
const newsBase = lang === 'uz' ? '/news/uz/' : lang === 'en' ? '/news/en/' : '/news/';

// Language switcher targets: on article pages we pass explicit per-language URLs;
// otherwise switch between the localized news indexes.
const langs = langUrls ?? { ru: '/news/', en: '/news/en/', uz: '/news/uz/' };

const t = {
  about:    lang === 'uz' ? 'Kompaniya haqida'    : lang === 'en' ? 'About Us'          : 'О компании',
  services: lang === 'uz' ? 'Xizmatlar'           : lang === 'en' ? 'Services'          : 'Услуги',
  projects: lang === 'uz' ? 'Loyihalar tajribasi' : lang === 'en' ? 'Project Experience': 'Опыт проектов',
  news:     lang === 'uz' ? 'Yangiliklar'         : lang === 'en' ? 'News'              : 'Новости',
  team:     lang === 'uz' ? 'Jamoa'               : lang === 'en' ? 'Team'              : 'Команда',
  contact:  lang === 'uz' ? 'Ariza qoldirish'     : lang === 'en' ? 'Request Consultation' : 'Оставить заявку',
  contactShort: lang === 'uz' ? 'Bog‘lanish' : lang === 'en' ? 'Contact'           : 'Связаться',
  toggleTheme: lang === 'uz' ? 'Mavzuni almashtirish' : lang === 'en' ? 'Toggle theme'  : 'Сменить тему',
};
const moonPath = 'M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z';
const sunPath = 'M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z';
---
<header class="fixed top-0 z-[100] w-full border-b border-gray-100 bg-white/95 backdrop-blur-md transition-all duration-300">
	<div class="relative z-[101] mx-auto flex h-20 max-w-7xl flex-nowrap items-center justify-between px-6">
		<a href={home} class="relative z-[101] block shrink-0">
			<img src="/bridge%202.svg" alt="Bridge Consult" class="site-logo h-9 object-contain md:h-11" />
		</a>

		<nav class="hidden flex-nowrap items-center space-x-5 lg:flex">
			<a href={`${home}#about`} class="nav-link text-sm font-medium transition-colors hover:text-bridge-taupe">{t.about}</a>
			<a href={`${home}#services`} class="nav-link text-sm font-medium transition-colors hover:text-bridge-taupe">{t.services}</a>
			<a href={projects} class="nav-link text-sm font-medium transition-colors hover:text-bridge-taupe">{t.projects}</a>
			<a href={newsBase} class="nav-link text-sm font-bold text-bridge-taupe border-b-2 border-bridge-taupe pb-1 transition-colors">{t.news}</a>
			<a href={`${home}#team`} class="nav-link text-sm font-medium transition-colors hover:text-bridge-taupe">{t.team}</a>
		</nav>

		<div class="hidden items-center space-x-4 lg:flex">
			<div class="flex items-center space-x-3 border-r border-gray-200 pr-4">
				<a href="https://www.linkedin.com/in/larissalk" target="_blank" class="flex h-10 w-10 items-center justify-center rounded-full bg-bridge-light text-bridge-taupe shadow-sm transition-all duration-300 hover:bg-bridge-taupe hover:text-white hover:shadow-md" title="LinkedIn">
					<svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
				</a>
				<a href="https://t.me/fidicuzb" target="_blank" class="flex h-10 w-10 items-center justify-center rounded-full bg-bridge-light text-bridge-taupe shadow-sm transition-all duration-300 hover:bg-bridge-taupe hover:text-white hover:shadow-md" title="Telegram">
					<svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm4.64 6.8c-.15 1.58-.8 5.42-1.13 7.19-.14.75-.42 1-.68 1.03-.58.05-1.02-.38-1.58-.75-.88-.58-1.38-.94-2.23-1.5-.99-.65-.35-1.01.22-1.59.15-.15 2.71-2.48 2.76-2.69.01-.03.01-.14-.07-.19-.08-.05-.19-.02-.27 0-.11.03-1.84 1.18-5.2 3.45-.49.33-.94.5-1.35.49-.45-.01-1.3-.25-1.94-.46-.78-.26-1.4-.4-1.34-.84.03-.23.36-.47.98-.72 3.85-1.68 6.42-2.78 7.71-3.32 3.67-1.53 4.43-1.8 4.93-1.81.11 0 .36.03.49.13.11.09.14.22.15.34.01.07.01.18 0 .22z"/></svg>
				</a>
			</div>

			<div class="flex items-center space-x-2 border-r border-gray-200 pr-4 text-xs font-bold uppercase tracking-widest">
				<a href={langs.ru} class={lang === 'ru' ? 'text-bridge-taupe border-b-2 border-bridge-taupe pb-0.5' : 'text-gray-400 hover:text-bridge-taupe transition-colors pb-0.5'}>RU</a>
				<span class="text-gray-200">|</span>
				<a href={langs.en} class={lang === 'en' ? 'text-bridge-taupe border-b-2 border-bridge-taupe pb-0.5' : 'text-gray-400 hover:text-bridge-taupe transition-colors pb-0.5'}>EN</a>
				<span class="text-gray-200">|</span>
				<a href={langs.uz} class={lang === 'uz' ? 'text-bridge-taupe border-b-2 border-bridge-taupe pb-0.5' : 'text-gray-400 hover:text-bridge-taupe transition-colors pb-0.5'}>UZ</a>
			</div>

			<button id="theme-toggle" type="button" title={t.toggleTheme} class="shrink-0 text-gray-500 hover:text-bridge-taupe focus:outline-none">
				<svg id="theme-toggle-dark-icon" class="h-5 w-5" fill="currentColor" viewBox="0 0 20 20"><path d={moonPath}></path></svg>
				<svg id="theme-toggle-light-icon" class="hidden h-5 w-5" fill="currentColor" viewBox="0 0 20 20"><path d={sunPath}></path></svg>
			</button>

			<div class="flex items-center space-x-3">
				<a href="tel:+998330001530" class="whitespace-nowrap text-sm font-bold tracking-wide text-bridge-dark transition-colors hover:text-bridge-taupe">+998 33 000 15 30</a>
				<a href={`${home}#contact-form`} class="whitespace-nowrap rounded-full bg-bridge-dark px-5 py-3 text-xs font-bold uppercase tracking-widest text-white shadow-md transition-colors hover:-translate-y-0.5 hover:bg-bridge-taupe">{t.contact}</a>
			</div>
		</div>

		<button id="mobile-menu-btn" class="relative z-[101] flex h-5 w-7 flex-col justify-between text-bridge-dark focus:outline-none lg:hidden" aria-label="Menu">
			<span class="burger-line-1 h-[2px] w-full origin-left bg-current transition-all duration-300"></span>
			<span class="burger-line-2 h-[2px] w-full bg-current transition-all duration-300"></span>
			<span class="burger-line-3 h-[2px] w-full origin-left bg-current transition-all duration-300"></span>
		</button>
	</div>

	<div id="mobile-menu" class="fixed inset-0 z-[100] flex h-[100dvh] w-full translate-x-full flex-col overflow-y-auto bg-white p-8 pt-28 transition-transform duration-500 lg:hidden">
		<div class="mb-10 flex items-center justify-center space-x-6 border-b border-gray-100 pb-6 text-sm font-bold uppercase tracking-widest">
			<a href={langs.ru} class={lang === 'ru' ? 'text-bridge-taupe border-b-2 border-bridge-taupe pb-1' : 'text-gray-400 hover:text-bridge-taupe transition-colors pb-1'}>RU</a>
			<a href={langs.en} class={lang === 'en' ? 'text-bridge-taupe border-b-2 border-bridge-taupe pb-1' : 'text-gray-400 hover:text-bridge-taupe transition-colors pb-1'}>EN</a>
			<a href={langs.uz} class={lang === 'uz' ? 'text-bridge-taupe border-b-2 border-bridge-taupe pb-1' : 'text-gray-400 hover:text-bridge-taupe transition-colors pb-1'}>UZ</a>
			<button id="mobile-theme-toggle" type="button" title={t.toggleTheme} class="ml-2 text-gray-400 transition-colors hover:text-bridge-taupe focus:outline-none">
				<svg id="mobile-theme-toggle-dark-icon" class="h-5 w-5" fill="currentColor" viewBox="0 0 20 20"><path d={moonPath}></path></svg>
				<svg id="mobile-theme-toggle-light-icon" class="hidden h-5 w-5" fill="currentColor" viewBox="0 0 20 20"><path d={sunPath}></path></svg>
			</button>
		</div>
		<div class="flex flex-col space-y-5">
			<a href={`${home}#about`} class="mobile-nav-link border-b border-gray-100 pb-3 text-2xl font-bold text-bridge-dark">{t.about}</a>
			<a href={`${home}#services`} class="mobile-nav-link border-b border-gray-100 pb-3 text-2xl font-bold text-bridge-dark">{t.services}</a>
			<a href={projects} class="mobile-nav-link border-b border-gray-100 pb-3 text-2xl font-bold text-bridge-dark">{t.projects}</a>
			<a href={newsBase} class="mobile-nav-link border-b border-gray-100 pb-3 text-2xl font-bold text-bridge-taupe">{t.news}</a>
			<a href={`${home}#team`} class="mobile-nav-link border-b border-gray-100 pb-3 text-2xl font-bold text-bridge-dark">{t.team}</a>
			<a href={`${home}#contact-form`} class="mobile-nav-link border-b border-gray-100 pb-3 pt-2 text-2xl font-bold text-bridge-dark">{t.contact}</a>
		</div>
		<div class="mt-10 flex flex-col space-y-4">
			<a href="tel:+998330001530" class="text-center text-xl font-semibold text-bridge-dark">+998 33 000 15 30</a>
		</div>
	</div>
</header>
