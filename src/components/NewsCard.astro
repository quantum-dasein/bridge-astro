---
interface Props {
	slug: string;
	title: string;
	date: Date;
	excerpt: string;
	coverImage: string;
	tags: string[];
	index?: number;
}

const { slug, title, date, excerpt, coverImage, tags, index = 0 } = Astro.props;

const formattedDate = new Intl.DateTimeFormat('ru-RU', {
	day: 'numeric',
	month: 'long',
	year: 'numeric',
}).format(date);
---

<article
	class="glass-card hover-float rounded-3xl overflow-hidden group cursor-pointer"
	data-aos="fade-up"
	data-aos-delay={index * 100}
>
	<a href={`/news/${slug}/`} class="block">
		<!-- Cover image -->
		<div class="relative aspect-[16/10] overflow-hidden bg-bridge-dark/50">
			<img
				src={coverImage}
				alt={title}
				class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-700 group-hover:scale-105"
				loading="lazy"
			/>
			<div class="absolute inset-0 bg-gradient-to-t from-bridge-dark/80 via-bridge-dark/20 to-transparent"></div>

			<!-- Tags overlay -->
			<div class="absolute top-4 left-4 flex flex-wrap gap-2">
				{
					tags.slice(0, 2).map((tag) => (
						<span class="text-[10px] font-bold uppercase tracking-widest bg-bridge-taupe text-white px-3 py-1 rounded-full shadow-lg">
							{tag}
						</span>
					))
				}
			</div>
		</div>

		<!-- Card body -->
		<div class="p-6 md:p-8">
			<time class="text-xs font-bold uppercase tracking-[0.22em] text-bridge-taupe block mb-3" datetime={date.toISOString()}>
				{formattedDate}
			</time>

			<h2 class="text-xl md:text-2xl font-bold text-white leading-snug mb-3 group-hover:text-bridge-taupe transition-colors duration-300">
				{title}
			</h2>

			<p class="text-sm text-gray-400 font-light leading-relaxed line-clamp-3 mb-5">
				{excerpt}
			</p>

			<span class="inline-flex items-center gap-3 text-xs font-bold uppercase tracking-widest text-bridge-taupe">
				Читать
				<span class="h-px w-8 bg-bridge-taupe transition-all duration-300 group-hover:w-14"></span>
			</span>
		</div>
	</a>
</article>
