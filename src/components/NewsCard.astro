---
import type { CollectionEntry } from 'astro:content';

interface Props {
	post: CollectionEntry<'news'>;
	index?: number;
	featured?: boolean;
}

const { post, index = 0, featured = false } = Astro.props;
const { title, date, excerpt, coverImage, tags } = post.data;
const slug = post.id.replace(/\.(md|mdx)$/i, '');
const formattedDate = new Intl.DateTimeFormat('ru-RU', {
	day: 'numeric',
	month: 'long',
	year: 'numeric',
}).format(date);
---

<article
	class:list={[
		'group relative overflow-hidden rounded-3xl border border-white/10 bg-white/5 backdrop-blur-lg transition-all duration-500 hover:-translate-y-1 hover:border-bridge-taupe/50 hover:shadow-[0_8px_40px_-8px_rgba(184,155,114,0.25)]',
		featured ? 'md:col-span-2 lg:col-span-2' : '',
	]}
	data-aos="fade-up"
	data-aos-delay={index * 100}
>
	<a href={`/news/${slug}/`} class:list={['block h-full', featured ? 'md:grid md:grid-cols-2 md:items-stretch' : 'flex flex-col']}>
		<div class:list={['relative overflow-hidden bg-bridge-dark', featured ? 'aspect-[16/10] md:h-full md:aspect-auto' : 'aspect-[16/10]']}>
			<img
				src={coverImage}
				alt={title}
				class="h-full w-full object-cover transition-transform duration-[900ms] ease-out group-hover:scale-105"
				loading="lazy"
			/>
			<div class="absolute inset-0 bg-gradient-to-t from-bridge-dark/80 via-bridge-dark/10 to-transparent"></div>
			<div class="absolute left-5 top-5 flex flex-wrap gap-2">
				{tags.slice(0, 2).map((tag) => (
					<span class="rounded-full border border-bridge-taupe/40 bg-bridge-dark/40 px-3 py-1 text-[10px] font-bold uppercase tracking-widest text-bridge-taupe backdrop-blur-md">
						{tag}
					</span>
				))}
			</div>
		</div>
		<div class:list={['flex h-full flex-col', featured ? 'p-8 md:p-10 md:justify-center' : 'p-6 md:p-7']}>
			<time class="mb-4 text-xs font-bold uppercase tracking-[0.22em] text-bridge-taupe" datetime={date.toISOString()}>
				{formattedDate}
			</time>
			<h2 class:list={['mb-4 font-bold leading-tight text-white transition-colors group-hover:text-bridge-taupe', featured ? 'text-2xl md:text-4xl' : 'text-xl md:text-2xl']}>
				{title}
			</h2>
			<p class:list={['mb-6 font-light leading-relaxed text-gray-400', featured ? 'text-base md:text-lg' : 'text-sm']}>
				{excerpt}
			</p>
			<span class="mt-auto inline-flex items-center text-xs font-bold uppercase tracking-widest text-white">
				Читать публикацию
				<span class="ml-3 h-px w-10 bg-bridge-taupe transition-all duration-300 group-hover:w-16"></span>
			</span>
		</div>
	</a>
</article>
