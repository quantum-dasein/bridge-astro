---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import SiteHeader from '../../../components/SiteHeader.astro';
import SiteFooter from '../../../components/SiteFooter.astro';

export async function getStaticPaths() {
	const posts = (await getCollection('news')).filter((p) => p.data.lang === 'uz');
	return posts.map((post) => ({
		params: { slug: post.id.replace(/^uz-/, '').replace(/\.(md|mdx)$/i, '') },
		props: { post },
	}));
}

interface Props { post: CollectionEntry<'news'>; }
const { post } = Astro.props;
const { Content } = await render(post);
const { title, date, excerpt, coverImage, tags } = post.data;
const video = post.data.videoUrl;
const currentSlug = Astro.params.slug as string;
const langUrls = {
	ru: `https://www.bridgeconsult.uz/news/ru-${currentSlug}/`,
	en: `https://www.bridgeconsult.uz/news/en/${currentSlug}/`,
	uz: `https://www.bridgeconsult.uz/news/uz/${currentSlug}/`,
};
const pageTitle = `${title} | Bridge Consult`;
const pageUrl = new URL(Astro.url.pathname, Astro.site ?? Astro.url.origin).toString();
const encodedUrl = encodeURIComponent(pageUrl);
const encodedTitle = encodeURIComponent(title);
const formattedDate = new Intl.DateTimeFormat('uz-UZ', { day: 'numeric', month: 'long', year: 'numeric' }).format(date);
---

<Layout title={pageTitle} description={excerpt} image={coverImage} type="article" lang="uz">
	<SiteHeader active="news" lang="uz" langUrls={langUrls} />

	<article class="bg-bridge-light font-sans">
		<header class="relative overflow-hidden bg-bridge-dark pt-36 pb-16 md:pt-44 md:pb-24" style="will-change:transform">
			<div class="absolute inset-0 z-0">
				<img src={coverImage} alt="" onerror="this.onerror=null;this.src='/larisa-belousova-uznews.png'" class="h-full w-full object-cover object-center opacity-35 grayscale" />
				<div class="absolute inset-0 bg-gradient-to-b from-bridge-dark/95 via-bridge-dark/75 to-bridge-dark"></div>
			</div>
			<div class="absolute left-1/2 top-1/2 z-[1] h-[560px] w-[560px] -translate-x-1/2 -translate-y-1/2 rounded-full bg-bridge-taupe/20 blur-[150px]" style="will-change:filter"></div>
			<div class="relative z-10 mx-auto max-w-4xl px-6 text-center">
				<a href="/news/uz/" class="mb-8 inline-flex items-center text-xs font-bold uppercase tracking-[0.24em] text-bridge-taupe transition-colors hover:text-white" data-aos="fade-up">
					<svg class="mr-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16l-4-4m0 0l4-4m-4 4h18"/></svg>
					Barcha yangiliklar
				</a>
				<div class="mb-5 flex flex-wrap justify-center gap-2" data-aos="fade-up" data-aos-delay="50">
					{tags.map((tag) => (
						<span class="rounded-full border border-white/15 bg-white/10 px-4 py-1.5 text-[10px] font-bold uppercase tracking-widest text-white backdrop-blur-md">{tag}</span>
					))}
				</div>
				<h1 class="mb-6 text-3xl font-bold leading-tight tracking-tight text-white md:text-5xl" data-aos="fade-up" data-aos-delay="100">{title}</h1>
				<div class="flex items-center justify-center gap-4 text-xs font-bold uppercase tracking-[0.24em] text-bridge-taupe" data-aos="fade-up" data-aos-delay="200">
					<time datetime={date.toISOString()}>{formattedDate}</time>
					<span class="h-1 w-1 rounded-full bg-bridge-taupe/50"></span>
					<span>Bridge Consult</span>
				</div>
			</div>
		</header>

		<section class="relative py-12 md:py-20">
			<div class="relative z-10 mx-auto max-w-3xl px-6">
				<figure class="-mt-24 mb-10 overflow-hidden rounded-3xl bg-bridge-dark shadow-[0_30px_70px_-20px_rgba(26,24,22,0.45)] md:-mt-32" data-aos="fade-up">
					<img src={coverImage} alt={title} class="aspect-[16/10] w-full object-cover" />
				</figure>
				<p class="mb-10 border-l-2 border-bridge-taupe pl-6 text-lg font-light italic leading-relaxed text-bridge-dark md:text-xl" data-aos="fade-up">{excerpt}</p>
				<div class="news-body" data-aos="fade-up" data-aos-delay="100"><Content /></div>

				{video && (
					<div class="my-14 flex flex-col items-center" data-aos="fade-up">
						<div class="w-full max-w-[320px] overflow-hidden rounded-3xl bg-bridge-dark shadow-[0_40px_90px_-15px_rgba(26,24,22,0.6)] ring-1 ring-white/10">
							<div class="relative w-full" style="aspect-ratio:9/16">
								<video controls playsinline preload="metadata" class="absolute inset-0 h-full w-full object-cover">
									<source src={video} type="video/mp4" />
								</video>
							</div>
						</div>
						<p class="mt-4 text-[10px] font-bold uppercase tracking-[0.28em] text-bridge-taupe">FIDIC OSH — Birinchi uchrashuv</p>
					</div>
				)}

				<div class="mt-12 border-t border-gray-200 pt-8 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-6">
					<a href="/news/uz/" class="inline-flex items-center gap-3 text-xs font-bold uppercase tracking-widest text-bridge-dark transition-colors hover:text-bridge-taupe">
						<svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16l-4-4m0 0l4-4m-4 4h18"/></svg>
						Barcha yangiliklar
					</a>
					<div class="flex items-center gap-3 shrink-0">
						<span class="text-[10px] font-bold uppercase tracking-[0.2em] text-gray-400">Ulashish</span>
						<div class="w-px h-4 bg-gray-200"></div>
						<a href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodedUrl}`} target="_blank" rel="noopener" class="share-btn">
							<svg class="h-3.5 w-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
							<span>LinkedIn</span>
						</a>
						<a href={`https://t.me/share/url?url=${encodedUrl}&text=${encodedTitle}`} target="_blank" rel="noopener" class="share-btn">
							<svg class="h-3.5 w-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
							<span>Telegram</span>
						</a>
					</div>
				</div>
			</div>
		</section>
	</article>

	<SiteFooter lang="uz" />
</Layout>

<style>
	:global(.share-btn) { display:inline-flex; align-items:center; gap:6px; padding:7px 16px; border-radius:999px; border:1px solid #e5e1db; background:transparent; color:#292724; font-size:11px; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; text-decoration:none; transition:background 0.2s,color 0.2s,border-color 0.2s,transform 0.15s; }
	:global(.share-btn:hover) { background:#292724; color:#F5F4F2; border-color:#292724; transform:translateY(-1px); }
	:global(.share-btn svg) { opacity:0.5; transition:opacity 0.2s; }
	:global(.share-btn:hover svg) { opacity:1; }
	.news-body :global(p) { margin-bottom:1.5rem; color:#4b5563; font-size:1.08rem; font-weight:300; line-height:1.9; }
	.news-body :global(strong) { color:#292724; font-weight:700; }
	.news-body :global(h2) { display:flex; align-items:center; gap:.75rem; margin:2.5rem 0 1.25rem; font-size:1.5rem; font-weight:700; color:#292724; }
	.news-body :global(h2::before) { content:''; display:inline-block; width:2rem; height:3px; border-radius:999px; background:#8A7B66; }
	.news-body :global(ul) { margin:0 0 1.5rem; padding-left:1.25rem; list-style:none; }
	.news-body :global(li) { position:relative; margin-bottom:.75rem; padding-left:1.25rem; color:#4b5563; font-weight:300; line-height:1.8; }
	.news-body :global(li::before) { content:''; position:absolute; left:0; top:.7em; width:6px; height:6px; border-radius:999px; background:#8A7B66; }
	.news-body :global(blockquote) { margin:2rem 0; padding:1.25rem 1.5rem; border-left:3px solid #8A7B66; background:#f5f4f2; border-radius:0 1rem 1rem 0; font-style:italic; color:#292724; }
</style>
