---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import SiteHeader from '../../../components/SiteHeader.astro';
import SiteFooter from '../../../components/SiteFooter.astro';

export async function getStaticPaths() {
	const posts = (await getCollection('news')).filter((p) => p.data.lang === 'uz');
	return posts.map((post) => ({
		params: { slug: post.id.replace(/^uz-/, '').replace(/\.(md|mdx)$/i, '') },
		props: { post },
	}));
}

interface Props { post: CollectionEntry<'news'>; }
const { post } = Astro.props;
const { Content } = await render(post);
const { title, date, excerpt, coverImage, tags } = post.data;
const pageTitle = `${title} | Bridge Consult`;
const formattedDate = new Intl.DateTimeFormat('uz-UZ', { day: 'numeric', month: 'long', year: 'numeric' }).format(date);
---

<Layout title={pageTitle} description={excerpt} image={coverImage} type="article" lang="uz">
	<SiteHeader active="news" lang="uz" />

	<article class="bg-bridge-light font-sans">
		<header class="relative overflow-hidden bg-bridge-dark pt-36 pb-16 md:pt-44 md:pb-24">
			<div class="absolute inset-0 z-0">
				<img src="/images/news/news-cover.jpg" alt="" class="h-full w-full object-cover opacity-30" />
				<div class="absolute inset-0 bg-gradient-to-b from-bridge-dark/95 via-bridge-dark/75 to-bridge-dark"></div>
			</div>
			<div class="absolute left-1/2 top-1/2 z-[1] h-[560px] w-[560px] -translate-x-1/2 -translate-y-1/2 rounded-full bg-bridge-taupe/20 blur-[150px]"></div>
			<div class="relative z-10 mx-auto max-w-4xl px-6 text-center">
				<a href="/news/uz/" class="mb-8 inline-flex items-center text-xs font-bold uppercase tracking-[0.24em] text-bridge-taupe transition-colors hover:text-white" data-aos="fade-up">
					<svg class="mr-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16l-4-4m0 0l4-4m-4 4h18"/></svg>
					Barcha yangiliklar
				</a>
				<div class="mb-5 flex flex-wrap justify-center gap-2" data-aos="fade-up" data-aos-delay="50">
					{tags.map((tag) => (
						<span class="rounded-full border border-white/15 bg-white/10 px-4 py-1.5 text-[10px] font-bold uppercase tracking-widest text-white backdrop-blur-md">{tag}</span>
					))}
				</div>
				<h1 class="mb-6 text-3xl font-bold leading-tight tracking-tight text-white md:text-5xl" data-aos="fade-up" data-aos-delay="100">{title}</h1>
				<div class="flex items-center justify-center gap-4 text-xs font-bold uppercase tracking-[0.24em] text-bridge-taupe" data-aos="fade-up" data-aos-delay="200">
					<time datetime={date.toISOString()}>{formattedDate}</time>
					<span class="h-1 w-1 rounded-full bg-bridge-taupe/50"></span>
					<span>Bridge Consult</span>
				</div>
			</div>
		</header>

		<section class="relative py-12 md:py-20">
			<div class="relative z-10 mx-auto max-w-3xl px-6">
				<figure class="-mt-24 mb-10 overflow-hidden rounded-3xl bg-bridge-dark shadow-[0_30px_70px_-20px_rgba(26,24,22,0.45)] md:-mt-32" data-aos="fade-up">
					<img src={coverImage} alt={title} class="aspect-[16/10] w-full object-cover" />
				</figure>
				<p class="mb-10 border-l-2 border-bridge-taupe pl-6 text-lg font-light italic leading-relaxed text-bridge-dark md:text-xl" data-aos="fade-up">{excerpt}</p>
				<div class="news-body" data-aos="fade-up" data-aos-delay="100"><Content /></div>
				<div class="mt-12 border-t border-gray-200 pt-8">
					<a href="/news/uz/" class="inline-flex items-center gap-3 text-xs font-bold uppercase tracking-widest text-bridge-dark transition-colors hover:text-bridge-taupe">
						<svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16l-4-4m0 0l4-4m-4 4h18"/></svg>
						Barcha nashrlar
					</a>
				</div>
			</div>
		</section>
	</article>

	<SiteFooter lang="uz" />
</Layout>

<style>
	.news-body :global(p) { margin-bottom:1.5rem; color:#4b5563; font-size:1.08rem; font-weight:300; line-height:1.9; }
	.news-body :global(strong) { color:#292724; font-weight:700; }
	.news-body :global(h2) { display:flex; align-items:center; gap:.75rem; margin:2.5rem 0 1.25rem; font-size:1.5rem; font-weight:700; color:#292724; }
	.news-body :global(h2::before) { content:''; display:inline-block; width:2rem; height:3px; border-radius:999px; background:#8A7B66; }
	.news-body :global(ul) { margin:0 0 1.5rem; padding-left:1.25rem; list-style:none; }
	.news-body :global(li) { position:relative; margin-bottom:.75rem; padding-left:1.25rem; color:#4b5563; font-weight:300; line-height:1.8; }
	.news-body :global(li::before) { content:''; position:absolute; left:0; top:.7em; width:6px; height:6px; border-radius:999px; background:#8A7B66; }
	.news-body :global(blockquote) { margin:2rem 0; padding:1.25rem 1.5rem; border-left:3px solid #8A7B66; background:#f5f4f2; border-radius:0 1rem 1rem 0; font-style:italic; color:#292724; }
</style>
