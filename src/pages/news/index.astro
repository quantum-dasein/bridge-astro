---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import NewsCard from '../../components/NewsCard.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';

const newsPosts = (await getCollection('news')).sort(
	(a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
---

<Layout
	title="Новости | Bridge Consult"
	description="Новости, аналитика и профессиональные публикации Bridge Consult о FIDIC, инфраструктурных контрактах и управлении строительными проектами."
	image="/images/news/news-cover.jpg"
>
	<SiteHeader active="news" />

	<section class="relative overflow-hidden bg-bridge-dark pt-40 pb-28 font-sans md:pt-48 md:pb-36">
		<div class="absolute inset-0 z-0">
			<img src="/images/news/news-cover.jpg" alt="" class="h-full w-full object-cover" />
		</div>
		<!-- Виньетка: затемняет края для читаемости, центр оставляет открытым -->
		<div class="absolute inset-0 z-[1]" style="background: radial-gradient(ellipse 80% 70% at center, rgba(26,24,22,0.15) 0%, rgba(26,24,22,0.5) 60%, rgba(26,24,22,0.85) 100%);"></div>
		<!-- Плавный переход к секции ниже + затемнение под шапкой -->
		<div class="absolute inset-0 z-[1] bg-gradient-to-b from-bridge-dark/70 via-transparent to-bridge-dark"></div>

		<div class="relative z-10 mx-auto max-w-7xl px-6 text-center">
			<div class="mb-5 flex items-center justify-center text-xs font-bold uppercase tracking-[0.28em] text-bridge-taupe" data-aos="fade-up">
				<span class="mr-4 h-px w-10 bg-bridge-taupe"></span>
				Newsroom
				<span class="ml-4 h-px w-10 bg-bridge-taupe"></span>
			</div>
			<h1 class="mb-6 text-4xl font-bold tracking-tight text-white md:text-6xl lg:text-7xl" data-aos="fade-up" data-aos-delay="100">
				Новости и <span class="text-bridge-taupe">экспертные публикации</span>
			</h1>
			<p class="mx-auto max-w-3xl text-lg font-light leading-relaxed text-gray-300 md:text-xl" data-aos="fade-up" data-aos-delay="200">
				Профессиональные заметки о контрактах FIDIC, инфраструктурных проектах, роли Инженера и развитии отраслевого сообщества.
			</p>
		</div>
	</section>

	<section class="relative overflow-hidden bg-bridge-light py-16 font-sans md:py-24">
		<div class="absolute -left-32 top-20 h-72 w-72 rounded-full bg-bridge-taupe/10 blur-3xl"></div>
		<div class="absolute -right-32 bottom-20 h-72 w-72 rounded-full bg-bridge-dark/10 blur-3xl"></div>

		<div class="relative z-10 mx-auto max-w-7xl px-6">
			<div class="mb-12 flex flex-col justify-between gap-6 md:mb-16 md:flex-row md:items-end">
				<div class="max-w-2xl" data-aos="fade-up">
					<div class="mb-4 flex items-center text-xs font-bold uppercase tracking-widest text-bridge-taupe">
						<span class="mr-4 h-px w-8 bg-bridge-taupe"></span>
						Latest insights
					</div>
					<h2 class="text-3xl font-bold leading-tight text-bridge-dark md:text-5xl">Актуальные материалы</h2>
				</div>
				<p class="max-w-md text-base font-light leading-relaxed text-gray-600 md:text-lg" data-aos="fade-up" data-aos-delay="100">
					Короткая форма, сильная экспертиза и практический взгляд на управление инфраструктурными контрактами.
				</p>
			</div>

			{newsPosts.length > 0 ? (
				<div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
					{newsPosts.map((post, index) => <NewsCard post={post} index={index} />)}
				</div>
			) : (
				<div class="rounded-3xl border border-white/70 bg-white p-10 text-center premium-shadow" data-aos="fade-up">
					<p class="text-lg font-light text-gray-600">Публикации скоро появятся.</p>
				</div>
			)}
		</div>
	</section>

	<SiteFooter />
</Layout>
