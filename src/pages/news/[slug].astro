---
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';

export async function getStaticPaths() {
	const posts = await getCollection('news');
	return posts.map((post) => ({
		params: { slug: post.id.replace(/\.(md|mdx)$/i, '') },
		props: { post },
	}));
}

type Props = { post: CollectionEntry<"news">; };

const { post } = Astro.props;
const { Content } = await render(post);
const { title, date, excerpt, coverImage, tags, lang } = post.data;

const currentSlug = Astro.params.slug as string;
const baseSlug = currentSlug.replace(/^(ru|en|uz)-/, '');
const langUrls = {
  ru: `/news/ru-${baseSlug}/`,
  en: `/news/en-${baseSlug}/`,
  uz: `/news/uz-${baseSlug}/`,
};

const pageTitle = `${title} | Bridge Consult`;
const pageUrl = new URL(Astro.url.pathname, Astro.site ?? Astro.url.origin).toString();
const absoluteImage = coverImage.startsWith('http') ? coverImage : new URL(coverImage, pageUrl).toString();
const formattedDate = new Intl.DateTimeFormat('ru-RU', { day: 'numeric', month: 'long', year: 'numeric' }).format(date);
---

<Layout title={pageTitle} description={excerpt} image={coverImage} type="article" lang={lang}>
	<SiteHeader lang={lang} />
	
	<article class="bg-bridge-light font-sans pb-16 md:pb-24">
		<header class="relative overflow-hidden bg-bridge-dark pt-36 pb-16 md:pt-44 md:pb-24">
			<div class="absolute inset-0 z-0">
				<img src={coverImage} alt="" class="h-full w-full object-cover opacity-30 grayscale" />
				<div class="absolute inset-0 bg-gradient-to-b from-bridge-dark/95 via-bridge-dark/75 to-bridge-dark"></div>
			</div>
			
			<div class="relative z-10 mx-auto max-w-5xl px-6 text-center">
				<div class="mb-8 flex items-center justify-between flex-wrap gap-4">
					<a href="/news/" class="inline-flex items-center text-xs font-bold uppercase tracking-[0.24em] text-bridge-taupe transition-colors hover:text-white">
					  <span class="mr-3 h-px w-8 bg-bridge-taupe"></span>
					  Newsroom
					</a>
					<div class="flex items-center gap-3 text-xs font-bold uppercase tracking-widest">
					  <a href={langUrls.ru} class={`transition-colors ${lang === 'ru' ? 'text-bridge-taupe' : 'text-white/40 hover:text-white'}`}>RU</a>
					  <span class="text-white/20">|</span>
					  <a href={langUrls.en} class={`transition-colors ${lang === 'en' ? 'text-bridge-taupe' : 'text-white/40 hover:text-white'}`}>EN</a>
					  <span class="text-white/20">|</span>
					  <a href={langUrls.uz} class={`transition-colors ${lang === 'uz' ? 'text-bridge-taupe' : 'text-white/40 hover:text-white'}`}>UZ</a>
					</div>
				</div>
				<h1 class="mb-6 text-3xl font-bold leading-tight tracking-tight text-white md:text-5xl lg:text-6xl">{title}</h1>
				<div class="flex items-center justify-center gap-4 text-xs font-bold uppercase tracking-[0.24em] text-bridge-taupe">
					<time datetime={date.toISOString()}>{formattedDate}</time>
					<span class="h-1 w-1 rounded-full bg-bridge-taupe/50"></span>
					<span>Bridge Consult</span>
				</div>
			</div>
		</header>

		<section class="relative py-12 md:py-20">
			<div class="relative z-10 mx-auto max-w-3xl px-6">
				<div class="news-body rounded-3xl border border-gray-200 bg-white p-7 shadow-xl md:p-12">
					<Content />
				</div>
				<div class="mt-12 pt-8 text-center md:text-left">
					<a href={`/news/${lang === 'ru' ? '' : lang + '/'}`} class="inline-flex items-center gap-3 text-xs font-bold uppercase tracking-widest text-bridge-dark transition-colors hover:text-bridge-taupe">
						<svg class="h-4 w-4 transform rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
						Назад к публикациям
					</a>
				</div>
			</div>
		</section>
	</article>
	<SiteFooter />
</Layout>

<style>
	.news-body :global(p) { margin-bottom: 1.5rem; color: #4b5563; line-height: 1.9; }
	.news-body :global(h2) { font-size: 1.5rem; font-weight: 700; color: #292724; margin: 2.5rem 0 1.25rem; }
</style>
