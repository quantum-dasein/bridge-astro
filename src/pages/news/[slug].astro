---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';

export async function getStaticPaths() {
	const posts = await getCollection('news');

	return posts.map((post) => ({
		params: { slug: post.id.replace(/\.(md|mdx)$/i, '') },
		props: { post },
	}));
}

interface Props {
	post: CollectionEntry<'news'>;
}

const { post } = Astro.props;
const { Content } = await render(post);
const { title, date, excerpt, coverImage, tags, lang } = post.data;
const pageTitle = `${title} | Bridge Consult`;
const pageUrl = new URL(Astro.url.pathname, Astro.site ?? Astro.url.origin).toString();
const absoluteImage = coverImage.startsWith('http') ? coverImage : new URL(coverImage, pageUrl).toString();
const formattedDate = new Intl.DateTimeFormat('ru-RU', {
	day: 'numeric',
	month: 'long',
	year: 'numeric',
}).format(date);

// Related posts (other than current)
const related = (await getCollection('news'))
	.filter((p) => p.id !== post.id)
	.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
	.slice(0, 2)
	.map((p) => {
		const slug = p.id.replace(/\.(md|mdx)$/i, '');
		return {
			slug,
			title: p.data.title,
			excerpt: p.data.excerpt,
			coverImage: p.data.coverImage,
			date: new Intl.DateTimeFormat('ru-RU', { day: 'numeric', month: 'long', year: 'numeric' }).format(p.data.date),
		};
	});

const newsArticleJsonLd = {
	'@context': 'https://schema.org',
	'@type': 'NewsArticle',
	headline: title,
	description: excerpt,
	image: [absoluteImage],
	datePublished: date.toISOString(),
	dateModified: date.toISOString(),
	mainEntityOfPage: { '@type': 'WebPage', '@id': pageUrl },
	author: { '@type': 'Organization', name: 'Bridge Consult', url: new URL('/index.html', pageUrl).toString() },
	publisher: {
		'@type': 'Organization',
		name: 'Bridge Consult',
		logo: { '@type': 'ImageObject', url: new URL('/bridge%202.png', pageUrl).toString() },
	},
};
---

<Layout title={pageTitle} description={excerpt} image={coverImage} type="article" lang={lang}>
	<Fragment slot="head">
		<meta property="article:published_time" content={date.toISOString()} />
		<meta property="article:modified_time" content={date.toISOString()} />
		{tags.map((tag) => <meta property="article:tag" content={tag} />)}
		<script type="application/ld+json" set:html={JSON.stringify(newsArticleJsonLd)}></script>
	</Fragment>

	<SiteHeader active="news" />

	<article class="bg-bridge-light font-sans">
		<!-- HERO -->
		<header class="relative overflow-hidden bg-bridge-dark pt-36 pb-16 md:pt-44 md:pb-24">
			<div class="absolute inset-0 z-0">
				<img src={coverImage} alt="" class="h-full w-full object-cover opacity-30 grayscale" />
				<div class="absolute inset-0 bg-gradient-to-b from-bridge-dark/95 via-bridge-dark/75 to-bridge-dark"></div>
			</div>
			<div class="absolute left-1/2 top-1/2 z-[1] h-[560px] w-[560px] -translate-x-1/2 -translate-y-1/2 rounded-full bg-bridge-taupe/20 blur-[150px]"></div>

			<div class="relative z-10 mx-auto max-w-4xl px-6 text-center">
				<a href="/news/" class="mb-8 inline-flex items-center text-xs font-bold uppercase tracking-[0.24em] text-bridge-taupe transition-colors hover:text-white" data-aos="fade-up">
					<svg class="mr-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16l-4-4m0 0l4-4m-4 4h18"/></svg>
					Все новости
				</a>
				<div class="mb-5 flex flex-wrap justify-center gap-2" data-aos="fade-up" data-aos-delay="50">
					{tags.map((tag) => (
						<span class="rounded-full border border-white/15 bg-white/10 px-4 py-1.5 text-[10px] font-bold uppercase tracking-widest text-white backdrop-blur-md">
							{tag}
						</span>
					))}
				</div>
				<h1 class="mb-6 text-3xl font-bold leading-tight tracking-tight text-white md:text-5xl lg:text-6xl" data-aos="fade-up" data-aos-delay="100">
					{title}
				</h1>
				<div class="flex items-center justify-center gap-4 text-xs font-bold uppercase tracking-[0.24em] text-bridge-taupe" data-aos="fade-up" data-aos-delay="200">
					<time datetime={date.toISOString()}>{formattedDate}</time>
					<span class="h-1 w-1 rounded-full bg-bridge-taupe/50"></span>
					<span>Bridge Consult</span>
				</div>
			</div>
		</header>

		<!-- КОНТЕНТ -->
		<section class="relative py-12 md:py-20">
			<div class="absolute -left-32 top-20 h-72 w-72 rounded-full bg-bridge-taupe/10 blur-3xl"></div>
			<div class="absolute -right-32 bottom-20 h-72 w-72 rounded-full bg-bridge-dark/10 blur-3xl"></div>

			<div class="relative z-10 mx-auto max-w-3xl px-6">
				<!-- Обложка в рамке -->
				<figure class="-mt-24 mb-10 overflow-hidden rounded-3xl bg-bridge-dark shadow-[0_30px_70px_-20px_rgba(26,24,22,0.45)] md:-mt-32" data-aos="fade-up">
					<img src={coverImage} alt={title} class="aspect-[16/10] w-full object-cover" />
				</figure>

				<!-- Лид -->
				<p class="mb-10 border-l-2 border-bridge-taupe pl-6 text-lg font-light italic leading-relaxed text-bridge-dark md:text-xl" data-aos="fade-up">
					{excerpt}
				</p>

				<!-- Тело статьи -->
				<div class="news-body" data-aos="fade-up" data-aos-delay="100">
					<Content />
				</div>

				<!-- Поделиться / назад -->
				<div class="mt-12 flex flex-col items-center justify-between gap-6 border-t border-gray-200 pt-8 sm:flex-row">
					<a href="/news/" class="inline-flex items-center gap-3 text-xs font-bold uppercase tracking-widest text-bridge-dark transition-colors hover:text-bridge-taupe">
						<svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16l-4-4m0 0l4-4m-4 4h18"/></svg>
						Все публикации
					</a>
					<div class="flex items-center gap-3">
						<span class="text-xs font-bold uppercase tracking-widest text-gray-400">Поделиться</span>
						<a href="https://t.me/share/url?url={pageUrl}" target="_blank" class="flex h-9 w-9 items-center justify-center rounded-full bg-bridge-dark text-white transition-colors hover:bg-bridge-taupe" title="Telegram">
							<svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm4.64 6.8c-.15 1.58-.8 5.42-1.13 7.19-.14.75-.42 1-.68 1.03-.58.05-1.02-.38-1.58-.75-.88-.58-1.38-.94-2.23-1.5-.99-.65-.35-1.01.22-1.59.15-.15 2.71-2.48 2.76-2.69.01-.03.01-.14-.07-.19-.08-.05-.19-.02-.27 0-.11.03-1.84 1.18-5.2 3.45-.49.33-.94.5-1.35.49z"/></svg>
						</a>
						<a href="https://www.linkedin.com/sharing/share-offsite/?url={pageUrl}" target="_blank" class="flex h-9 w-9 items-center justify-center rounded-full bg-bridge-dark text-white transition-colors hover:bg-bridge-taupe" title="LinkedIn">
							<svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
						</a>
					</div>
				</div>
			</div>
		</section>

		<!-- ПОХОЖИЕ -->
		{related.length > 0 && (
			<section class="border-t border-gray-200 bg-white py-16 md:py-24">
				<div class="mx-auto max-w-7xl px-6">
					<div class="mb-10 flex items-center gap-4" data-aos="fade-up">
						<span class="h-px w-8 bg-bridge-taupe"></span>
						<span class="text-xs font-bold uppercase tracking-widest text-bridge-taupe">Читайте также</span>
					</div>
					<div class="grid gap-8 md:grid-cols-2">
						{related.map((r, i) => (
							<a href={`/news/${r.slug}/`} class="group flex flex-col overflow-hidden rounded-3xl border border-gray-100 bg-bridge-light transition-all duration-500 hover:-translate-y-1 hover:shadow-[0_20px_40px_-10px_rgba(138,123,102,0.2)] sm:flex-row" data-aos="fade-up" data-aos-delay={i * 100}>
								<div class="relative h-48 overflow-hidden bg-bridge-dark sm:h-auto sm:w-2/5">
									<img src={r.coverImage} alt={r.title} class="h-full w-full object-cover grayscale transition-all duration-700 group-hover:scale-105 group-hover:grayscale-0" />
								</div>
								<div class="flex flex-col p-6 sm:w-3/5">
									<time class="mb-2 text-[10px] font-bold uppercase tracking-widest text-bridge-taupe">{r.date}</time>
									<h3 class="mb-2 text-lg font-bold leading-tight text-bridge-dark transition-colors group-hover:text-bridge-taupe">{r.title}</h3>
									<p class="line-clamp-2 text-sm font-light leading-relaxed text-gray-600">{r.excerpt}</p>
								</div>
							</a>
						))}
					</div>
				</div>
			</section>
		)}
	</article>

	<SiteFooter />
</Layout>

<style>
	.news-body :global(p) {
		margin-bottom: 1.5rem;
		color: #4b5563;
		font-size: 1.08rem;
		font-weight: 300;
		line-height: 1.9;
	}

	.news-body :global(strong) {
		color: #292724;
		font-weight: 700;
	}

	.news-body :global(h2) {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		margin: 2.5rem 0 1.25rem;
		font-size: 1.5rem;
		font-weight: 700;
		color: #292724;
		letter-spacing: -0.01em;
	}

	.news-body :global(h2::before) {
		content: '';
		display: inline-block;
		width: 2rem;
		height: 3px;
		border-radius: 999px;
		background: #8A7B66;
	}

	.news-body :global(h3) {
		margin: 2rem 0 1rem;
		font-size: 1.2rem;
		font-weight: 700;
		color: #292724;
	}

	.news-body :global(ul) {
		margin: 0 0 1.5rem;
		padding-left: 1.25rem;
		list-style: none;
	}

	.news-body :global(li) {
		position: relative;
		margin-bottom: 0.75rem;
		padding-left: 1.25rem;
		color: #4b5563;
		font-weight: 300;
		line-height: 1.8;
	}

	.news-body :global(li::before) {
		content: '';
		position: absolute;
		left: 0;
		top: 0.7em;
		width: 6px;
		height: 6px;
		border-radius: 999px;
		background: #8A7B66;
	}

	.news-body :global(hr) {
		margin: 2.5rem 0;
		border: none;
		border-top: 1px solid #e5e7eb;
	}

	.news-body :global(blockquote) {
		margin: 2rem 0;
		padding: 1.25rem 1.5rem;
		border-left: 3px solid #8A7B66;
		background: #f5f4f2;
		border-radius: 0 1rem 1rem 0;
		font-style: italic;
		color: #292724;
	}
</style>
